{
  "name": "@intend/bot",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:cron": "ts-node-dev --respawn --transpile-only src/cron.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cron": "node dist/cron.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@intend/core": "*",
    "@intend/intelligence": "*",
    "@intend/execution": "*",
    "@intend/data": "*",
    "@intend/signals": "*",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "typescript": "^5.0.0",
    "ts-node-dev": "^2.0.0"
  }
}
